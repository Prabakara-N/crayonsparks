rules_version = '2';

// CrayonSparks — Firestore Security Rules
//
// Architecture: ADMIN-ONLY. Every read/write to Firestore goes through
// server-side oRPC procedures running with the Firebase Admin SDK, which
// BYPASSES these rules entirely. The browser never touches Firestore
// directly.
//
// Therefore the correct stance is DENY EVERYTHING for client SDK access.
// If a rule ever needs to allow direct client access, add it explicitly
// and review carefully.
//
// To apply: Firebase Console → Firestore Database → Rules → paste → Publish.
// Or via CLI: firebase deploy --only firestore:rules

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
